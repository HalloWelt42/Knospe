# Umgebungsdatei mit Zugangsdaten und abgeleiteten Ports - nie einchecken
/.env
backend/.env

# Abhängigkeiten
/vendor/
backend/vendor/
node_modules/
frontend/node_modules/

# Build-Ausgaben
frontend/dist/

# Datenbank-Sicherungen (liegen bewusst im Projekt, aber nicht im Repo)
/backups/*
!/backups/.gitkeep

# JetBrains IDE (persönlicher Zustand)
/.idea/

# Betriebssystem
.DS_Store
Thumbs.db

# Werkzeug-Zwischenspeicher
backend/.phpunit.cache/
backend/.php-cs-fixer.cache

# Logs
*.log
