{
    "name": "hallowelt42/knospe",
    "description": "Lehr-Boilerplate: PHP 8.5 Mini-Kern mit Plugin-System",
    "type": "project",
    "license": "LicenseRef-Knospe-NC-1.0",
    "require": {
        "php": ">=8.5",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Knospe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Knospe\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "analyse": "phpstan analyse",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix"
    }
}
