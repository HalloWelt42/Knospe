#!/bin/sh
# ============================================================
# Knospe - Verwaltungsskript für den Alltag
# ============================================================
# Ein kleiner Helfer als einziger Einstieg. Jeder Befehl ruft im Kern nur
# dokumentierte Docker-, Composer- und npm-Kommandos auf - es passiert
# nichts Verstecktes, alles lässt sich auch von Hand ausführen.
# Lern mehr: docs/06-deployment/02-docker-befehle-alltag.md
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
cd "$ROOT_DIR"
ENV_FILE="$ROOT_DIR/.env"

# --- Hilfsfunktionen ---------------------------------------------------------

dc() { docker compose "$@"; }

load_env() {
  [ -f "$ENV_FILE" ] && . "$ENV_FILE" || true
}

ensure_env() {
  if [ ! -f "$ENV_FILE" ]; then
    sh "$ROOT_DIR/tools/setup-env.sh"
  fi
}

# --- Befehle -----------------------------------------------------------------

# Installiert die Backend-Abhängigkeiten (composer), falls sie fehlen.
# Nutzt einen Einweg-Container, braucht also keinen laufenden Stack.
ensure_deps() {
  if [ ! -f backend/vendor/autoload.php ]; then
    echo "[knospe] Installiere Backend-Abhängigkeiten (composer) ..."
    dc run --rm --no-deps php composer install --no-interaction
  fi
}

cmd_setup() {
  # Bei Erstinstallation nach einem Projekt-Postfix fragen (oder einen
  # mitgegebenen verwenden: ./knospe setup <postfix>).
  if [ ! -f "$ENV_FILE" ]; then
    if [ "$#" -gt 0 ] && [ -n "$1" ]; then
      sh "$ROOT_DIR/tools/setup-env.sh" "$1"
    else
      sh "$ROOT_DIR/tools/setup-env.sh" --ask
    fi
  fi
  echo "[knospe] Baue Images (das kann beim ersten Mal dauern) ..."
  dc build
  ensure_deps
  echo "[knospe] Bereit. Starten mit: ./knospe up"
}

cmd_up() {
  ensure_env
  # Auf einem frischen Klon fehlen die Composer-Abhängigkeiten - dann nachziehen.
  ensure_deps
  dc up -d
  # Migrationen laufen, sobald der Runner existiert (ab Meilenstein M2).
  if [ -f backend/bin/console ]; then
    echo "[knospe] Führe ausstehende Migrationen aus ..."
    dc exec -T php php bin/console migrate || true
  fi
  cmd_status
}

cmd_down() { dc down; }

cmd_restart() { dc restart; }

cmd_status() {
  load_env
  echo ""
  echo "  Knospe  (${COMPOSE_PROJECT_NAME:-nicht eingerichtet})"
  echo "  --------------------------------------------------"
  echo "  PHP-API :  http://localhost:${PHP_PORT:-?}/api/health"
  echo "  Frontend:  http://localhost:${VITE_PORT:-?}"
  echo "  Postgres:  localhost:${DB_PORT:-?}  (DB ${POSTGRES_DB:-?}, User ${POSTGRES_USER:-?})"
  echo ""
  dc ps 2>/dev/null || true
}

cmd_logs() { dc logs -f ${1:-}; }

cmd_migrate() { dc exec -T php php bin/console migrate; }

cmd_seed() { dc exec -T php php bin/console seed; }

cmd_update() {
  git pull --ff-only || true
  dc exec -T php composer install || true
  dc run --rm node npm ci || true
  [ -f backend/bin/console ] && dc exec -T php php bin/console migrate || true
  echo "[knospe] Aktualisierung abgeschlossen."
}

cmd_backup() {
  load_env
  mkdir -p backups
  TS=$(date +%Y%m%d-%H%M%S)
  OUT="backups/knospe-$TS.sql.gz"
  dc exec -T postgres pg_dump -U "${POSTGRES_USER}" "${POSTGRES_DB}" | gzip > "$OUT"
  echo "[knospe] Sicherung geschrieben: $OUT"
}

cmd_restore() {
  load_env
  FILE="${1:?Bitte Sicherungsdatei angeben: ./knospe restore <datei>}"
  [ -f "$FILE" ] || { echo "Datei nicht gefunden: $FILE"; exit 1; }
  echo "[knospe] Spiele $FILE ein ..."
  gunzip -c "$FILE" | dc exec -T postgres psql -U "${POSTGRES_USER}" -d "${POSTGRES_DB}"
  echo "[knospe] Wiederhergestellt."
}

cmd_reset() {
  printf "Das löscht Container UND das Datenbank-Volume dieser Installation. Fortfahren? [j/N] "
  read -r ans
  case "$ans" in
    j|J|y|Y) dc down -v; echo "[knospe] Zurückgesetzt." ;;
    *) echo "Abgebrochen." ;;
  esac
}

usage() {
  cat <<'EOF'
Knospe - Verwaltung

  ./knospe setup            .env erzeugen (falls fehlend) und Images bauen
  ./knospe up               Stack starten (führt Migrationen aus)
  ./knospe down             Stack stoppen
  ./knospe restart          Dienste neu starten
  ./knospe status           Adressen und Zustand anzeigen
  ./knospe logs [dienst]    Logs folgen (z.B. php, postgres, node)
  ./knospe migrate          Ausstehende Migrationen ausführen
  ./knospe seed             Startdaten einspielen
  ./knospe update           git pull + Abhängigkeiten + Migrationen
  ./knospe backup           Datenbank nach ./backups sichern
  ./knospe restore <datei>  Datenbank aus Sicherung wiederherstellen
  ./knospe reset            Alles zurücksetzen (löscht das DB-Volume!)
EOF
}

CMD="${1:-help}"
shift 2>/dev/null || true
case "$CMD" in
  setup)          cmd_setup "$@" ;;
  up|start)       cmd_up ;;
  down|stop)      cmd_down ;;
  restart)        cmd_restart ;;
  status|info)    cmd_status ;;
  logs)           cmd_logs "${1:-}" ;;
  migrate)        cmd_migrate ;;
  seed)           cmd_seed ;;
  update)         cmd_update ;;
  backup)         cmd_backup ;;
  restore)        cmd_restore "${1:-}" ;;
  reset)          cmd_reset ;;
  *)              usage ;;
esac
