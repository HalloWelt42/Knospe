# Einheitliche Editor-Einstellungen über alle Werkzeuge hinweg.
# Lern mehr: docs/09-entwicklung/01-code-style-psr-12.md
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.php]
indent_size = 4

[*.{js,ts,svelte,json,yml,yaml,css,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
