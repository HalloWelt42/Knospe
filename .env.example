# ============================================================
# Knospe - Umgebungskonfiguration (Vorlage)
# ============================================================
# Diese Datei wird eingecheckt und dient als Vorlage und Dokumentation.
# Die echte .env erzeugt "./knospe setup" (mit eindeutigem Projektnamen,
# freien Ports und erzeugten Geheimnissen). Die .env ist gitignored und
# wird nie ueberschrieben, sobald sie existiert.
# Lern mehr: docs/03-datenbank/02-zugangsdaten-verwalten.md

# --- Projekt-Isolation (aus dem Projektpfad abgeleitet) ---
# Eindeutiger Compose-Projektname. Trennt Container, Netz und das
# Postgres-Datenvolume von jeder anderen Installation.
COMPOSE_PROJECT_NAME=knospe

# --- Host-Ports (nur diese sind von aussen sichtbar) ---
# Werden beim Setup pfad-eindeutig gewaehlt, damit sich zwei
# Installationen nie stoeren. Container-intern bleiben die Ports fest.
PHP_PORT=8000
VITE_PORT=5173
# Host-Port zu PostgreSQL (fuer DataGrip/externe Werkzeuge und Bare-Metal);
# im Docker-Netz erreicht das Backend die Datenbank immer ueber "postgres:5432".
DB_PORT=15432

# --- Anwendung ---
APP_ENV=development
APP_DEBUG=true
# Zufaelliges Geheimnis (Sitzungen/CSRF). Beim Setup erzeugt.
APP_SECRET=bitte-beim-setup-erzeugen

# --- Datenbank (PostgreSQL) ---
POSTGRES_DB=knospe
POSTGRES_USER=knospe
POSTGRES_PASSWORD=bitte-beim-setup-erzeugen
